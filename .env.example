# Core Django settings
DJANGO_SECRET_KEY=replace-this-with-a-secure-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=Asia/Kolkata

# Local database fallback
# Leave DATABASE_URL empty to use local SQLite.
SQLITE_NAME=db.sqlite3

# Production database
# On Render, DATABASE_URL is normally injected automatically from render.yaml.
# You usually do not need to set it manually in local development.
# DATABASE_URL=postgresql://user:password@host:5432/database
